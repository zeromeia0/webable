# Webable — optional environment (copy to `.env`, never commit `.env`)

# --- Data (never delete this directory when updating) ---
# WEBABLE_DATA_DIR=./data

# --- Auto-update (git deployment: working tree + WEBABLE_AUTO_UPDATE) ---
# WEBABLE_AUTO_UPDATE=1
# WEBABLE_ALLOW_GIT_ROLLBACK=1
# WEBABLE_UPDATE_CACHE_TTL=300
# WEBABLE_GIT_UPDATE_USE_COMPOSE_RESTART=1
# WEBABLE_DOCKER_COMPOSE_PATH=/path/to/docker-compose.yml
# WEBABLE_COMPOSE_SERVICE=webable

# --- Deployment mode (optional override; default: git if .git exists else image) ---
# WEBABLE_DEPLOYMENT_MODE=git
# WEBABLE_DEPLOYMENT_MODE=image

# --- Image deployment: in-app compose pull/up (host must have Docker + valid compose file) ---
# WEBABLE_ALLOW_IMAGE_SELF_UPDATE=1
# WEBABLE_DOCKER_COMPOSE_PATH=/path/to/docker-compose.yml
# WEBABLE_DOCKER_COMPOSE_ALLOWED_ROOTS=/opt/stacks
# WEBABLE_EXPECT_EXTERNAL_UPDATER=1

# --- Update orchestration tuning ---
# WEBABLE_UPDATE_MIN_INTERVAL_SEC=60
# WEBABLE_ORCHESTRATION_TERMINAL_TTL_SEC=300
# WEBABLE_INTERNAL_HEALTH_URL=http://127.0.0.1:8000/health
# WEBABLE_UPDATE_HEALTH_TIMEOUT_SEC=120

# --- GitHub (public repo works without a token; token raises API rate limits) ---
# WEBABLE_GITHUB_OWNER=zeromeia0
# WEBABLE_GITHUB_REPO=webable
# WEBABLE_GITHUB_TOKEN=

# --- Local revision (Docker / CI: set at build or runtime) ---
# WEBABLE_GIT_COMMIT=abc123...
# WEBABLE_LOCAL_GIT_COMMIT=abc123...

# --- Release identity (optional overrides; otherwise VERSION file + .webable-git-rev in image) ---
# WEBABLE_APP_VERSION=1.0.0
# WEBABLE_CHANNEL=stable
# WEBABLE_BUILD_TIME=2026-05-18T12:00:00Z

# --- GHCR deploy: image tag when using docker-compose.image.yml (default: VERSION file) ---
# WEBABLE_VERSION=1.0.0

# --- Connectivity probe URL (HEAD request) ---
# WEBABLE_CONNECTIVITY_URL=https://github.com

# --- Optional AI (Ollama; app works fully without it) ---
# Docker Compose sets these for the webable service; override for local uvicorn:
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=minimax-m2.5:cloud
# Cloud-backed models are not auto-pulled. After `docker compose up`, sign in once:
#   docker exec -it webable-ollama ollama signin
#   docker exec -it webable-ollama ollama run minimax-m2.5:cloud
